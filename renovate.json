{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "1 day",
  "packageRules": [
    {
      "matchPackageNames": ["pnpm"],
      "groupName": "PNPM package manager"
    },
    {
      "matchFileNames": ["docs/package.json"],
      "groupName": "Documentation site dependencies"
    },
    {
      "matchFileNames": ["playground/package.json"],
      "groupName": "Playground dependencies"
    },
    {
      "matchFileNames": ["packages/*/package.json"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "Package devDependencies"
    },
    {
      "matchFileNames": ["packages/*/package.json"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Package dependencies"
    },
    {
      "matchFileNames": ["packages/*/package.json"],
      "matchUpdateTypes": ["major"],
      "groupName": "Package major dependencies"
    }
  ]
}
