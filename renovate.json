{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "1 day",
  "schedule": ["* * * * 0"],
  "packageRules": [
    {
      "matchPackageNames": ["pnpm"],
      "groupName": "PNPM"
    },
    {
      "matchFileNames": ["docs/package.json"],
      "matchPackageNames": ["@codemirror/*"],
      "groupName": "Docs CodeMirror"
    },
    {
      "matchFileNames": ["docs/package.json"],
      "matchPackageNames": ["@docusaurus/*"],
      "groupName": "Docs Engine"
    },
    {
      "matchFileNames": ["docs/package.json"],
      "groupName": "Docs"
    },
    {
      "matchFileNames": ["playground/package.json"],
      "groupName": "Playground"
    },
    {
      "matchFileNames": ["package.json"],
      "groupName": "Tooling"
    },
    {
      "matchFileNames": ["packages/*/package.json"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "Package devDependencies"
    },
    {
      "matchFileNames": ["packages/*/package.json"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Package dependencies"
    },
    {
      "matchFileNames": ["packages/*/package.json"],
      "matchUpdateTypes": ["major"],
      "groupName": "Package major dependencies"
    }
  ]
}
