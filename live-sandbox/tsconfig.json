{
  "compilerOptions": {
    "target": "ES2020",
    "jsx": "react",

    "module": "ES2020",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "isolatedModules": true,

    "downlevelIteration": true,

    "lib": ["dom", "es2020"],

    "strict": true,
    "skipLibCheck": true,

    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "sourceMap": true,

    "types": ["vite/client"]
  },
  "include": ["./src"]
}
