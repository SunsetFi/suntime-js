// Forced to be jsonc:
// Cannot use .ts as docusaurus forbids using "type": "module"
// Cannt use .mts as oxfmt ignores this.
{
  "ignorePatterns": [
    // Generated code
    "/static/playground-embed",
  ],
  "sortImports": {
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      ["type-internal", "value-internal"],
      ["type-parent", "value-parent"],
      ["type-sibling", "value-sibling"],
      ["type-index", "value-index"],
      "unknown",
    ],
  },
}
