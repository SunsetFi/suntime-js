{
  "name": "@suntime-js/docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "docusaurus start",
    "sync:playground": "pnpm --filter @suntime-js/playground... build && rm -rf static/playground-embed && cp -r ../playground/dist static/playground-embed",
    "sync:suntime": "dts-bundle-generator --config suntime-dts.config.cjs",
    "build": "docusaurus build",
    "serve": "docusaurus serve",
    "clean": "docusaurus clear",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc6",
    "test": "vitest run",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@docusaurus/core": "3.10.2",
    "@docusaurus/faster": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@docusaurus/theme-common": "3.10.2",
    "@docusaurus/theme-mermaid": "^3.10.1",
    "@mdx-js/react": "^3.1.1",
    "@suntime-js/core": "workspace:*",
    "@suntime-js/debugger": "workspace:*",
    "@typescript/vfs": "^1.6.4",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rxjs": "^7.8.2",
    "ts-blank-space": "^0.9.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dts-bundle-generator": "^9.5.1",
    "raw-loader": "^4.0.2",
    "typescript": "catalog:docusaurus",
    "vitest": "catalog:"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
