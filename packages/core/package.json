{
  "name": "@suntime-js/core",
  "version": "0.6.0",
  "private": false,
  "description": "Evaluate javascript in a sandboxed environment.",
  "keywords": [],
  "license": "ISC",
  "author": "SunsetFi",
  "repository": {
    "url": "https://github.com/SunsetFi/static-js"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "prepublish": "pnpm run clean && pnpm run build",
    "clean": "rimraf lib tsconfig.lib.tsbuildinfo",
    "build": "tsc -p tsconfig.lib.json",
    "check": "tsc -p tsconfig.lib.json --noEmit",
    "test": "vitest run --pool=threads --project=e2e",
    "test:262": "vitest run --pool=threads --project=test262",
    "test:baseline": "VITEST_COMPARE_BASELINE=1 pnpm test:262",
    "test:create-baseline": "pnpm test:262 --reporter=default --reporter=json --outputFile=tests/test-results-baseline.json --update",
    "test:view": "vite serve html",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "type-fest": "^4.37.0"
  },
  "devDependencies": {
    "@babel/types": "catalog:",
    "@types/babel__traverse": "catalog:",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.13.10",
    "@vitest/ui": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "oxfmt": "^0.35.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "vite": "^6.2.4",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  },
  "packageManager": "pnpm@10.6.2"
}
