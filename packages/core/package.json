{
  "name": "@suntime-js/core",
  "version": "0.7.0",
  "private": false,
  "description": "Evaluate javascript in a sandboxed environment.",
  "keywords": [],
  "license": "ISC",
  "author": "SunsetFi",
  "repository": {
    "url": "https://github.com/SunsetFi/static-js"
  },
  "engines": {
    "node": ">= 22"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "scripts": {
    "prepublish": "pnpm run clean && pnpm run build",
    "clean": "rimraf lib tsconfig.lib.tsbuildinfo",
    "build": "tsc -p tsconfig.lib.json",
    "check": "pnpm check:lib && pnpm check:tests",
    "check:lib": "tsgo -p tsconfig.lib.json --noEmit",
    "check:tests": "tsgo -p tsconfig.tests.json --noEmit",
    "gen:tests": "tsx ./tests/test262/generator/gen.ts",
    "test": "vitest run --project=e2e",
    "test:spec": "vitest run --project=spec",
    "test:e2e": "vitest run --project=e2e",
    "test:language": "vitest run --project=Test262:Language",
    "test:language:baseline": "pnpm test:language --tags-filter known-passing",
    "test:language:create-baseline": "VITEST_CREATE_BASELINE=1 pnpm test:language --update || pnpm gen:tests",
    "test:builtins": "vitest run --project=Test262:Built-ins",
    "test:builtins:baseline": "pnpm test:builtins --tags-filter known-passing",
    "test:builtins:create-baseline": "VITEST_CREATE_BUILTINS_BASELINE=1 pnpm test:builtins --update || pnpm gen:tests",
    "test:all": "vitest run --pool=threads",
    "test:view": "vite serve html",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "type-fest": "^4.37.0"
  },
  "devDependencies": {
    "@babel/types": "catalog:",
    "@types/babel__traverse": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.5",
    "yaml": "^2.8.2"
  },
  "packageManager": "pnpm@10.6.2"
}
