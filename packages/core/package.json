{
  "name": "@suntime-js/core",
  "version": "0.8.7",
  "private": false,
  "description": "Evaluate javascript in a sandboxed environment.",
  "keywords": [],
  "license": "ISC",
  "author": "SunsetFi",
  "repository": {
    "url": "https://github.com/SunsetFi/suntime-js"
  },
  "engines": {
    "node": ">= 22"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.lib.tsbuildinfo",
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "pnpm typecheck:lib && pnpm typecheck:tests",
    "typecheck:lib": "tsgo -p tsconfig.lib.json --noEmit",
    "typecheck:tests": "tsgo -p tsconfig.tests.json --noEmit",
    "gen:tests": "tsx ./tests/test262/generator/gen.ts",
    "test": "pnpm test:baseline",
    "test:baseline": "vitest run --project=Test262:Language --project=Test262:Built-ins --tags-filter known-passing",
    "test:create-baseline": "VITEST_CREATE_BASELINE=1 vitest run --project=Test262:Language --project=Test262:Built-ins --update && pnpm gen:tests",
    "test:spec": "vitest run --project=spec",
    "test:e2e": "vitest run --project=e2e",
    "test:language": "vitest run --project=Test262:Language",
    "test:language:baseline": "pnpm test:language --tags-filter known-passing",
    "test:builtins": "vitest run --project=Test262:Built-ins",
    "test:builtins:baseline": "pnpm test:builtins --tags-filter known-passing",
    "test:all": "vitest run --pool=threads",
    "test:view": "vite serve html",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0"
  },
  "devDependencies": {
    "@babel/types": "catalog:",
    "@types/babel__traverse": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.5",
    "yaml": "^2.8.2"
  },
  "packageManager": "pnpm@11.5.2"
}
