{
  "name": "@suntime-js/core",
  "version": "0.6.0",
  "private": false,
  "description": "Evaluate javascript in a sandboxed environment.",
  "keywords": [],
  "license": "ISC",
  "author": "SunsetFi",
  "repository": {
    "url": "https://github.com/SunsetFi/static-js"
  },
  "engines": {
    "node": ">= 22"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "scripts": {
    "prepublish": "pnpm run clean && pnpm run build",
    "clean": "rimraf lib tsconfig.lib.tsbuildinfo",
    "build": "tsc -p tsconfig.lib.json",
    "check": "tsc -p tsconfig.lib.json --noEmit",
    "gen:tests": "tsx ./tests/test262/gen.ts",
    "test": "vitest run --pool=threads --project=e2e",
    "test:spec": "vitest run --pool=threads --project=spec",
    "test:262": "vitest run --pool=threads --project=test262",
    "test:baseline": "VITEST_COMPARE_BASELINE=1 pnpm test:262",
    "test:create-baseline": "VITEST_CREATE_BASELINE=1 pnpm test:262 --update",
    "test:all": "vitest run --pool=threads",
    "test:view": "vite serve html",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "type-fest": "^4.37.0"
  },
  "devDependencies": {
    "@babel/types": "catalog:",
    "@types/babel__traverse": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "yaml": "^2.8.2"
  },
  "packageManager": "pnpm@10.6.2"
}
