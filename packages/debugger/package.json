{
  "name": "@suntime-js/debugger",
  "version": "0.8.0",
  "private": false,
  "description": "Runtime-agnostic debugger orchestration for Suntime-JS.",
  "license": "ISC",
  "author": "SunsetFi",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.lib.tsbuildinfo tsconfig.tests.tsbuildinfo",
    "lint": "oxlint",
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsgo -p tsconfig.lib.json --noEmit && tsgo -p tsconfig.tests.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt"
  },
  "dependencies": {
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/types": "catalog:",
    "@suntime-js/core": "workspace:^0.8.0",
    "@types/babel__traverse": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@suntime-js/core": "workspace:*"
  },
  "packageManager": "pnpm@11.5.2"
}
