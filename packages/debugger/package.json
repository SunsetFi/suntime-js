{
  "name": "@suntime-js/debugger",
  "version": "0.1.0",
  "private": false,
  "description": "Runtime-agnostic debugger orchestration for Suntime-JS.",
  "license": "ISC",
  "author": "SunsetFi",
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "scripts": {
    "prepublish": "pnpm run clean && pnpm run build",
    "clean": "rimraf lib tsconfig.lib.tsbuildinfo tsconfig.tests.tsbuildinfo",
    "build": "tsc -p tsconfig.lib.json",
    "check": "tsc -p tsconfig.lib.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt"
  },
  "dependencies": {
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@suntime-js/core": "workspace:*",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/types": "catalog:",
    "@types/babel__traverse": "catalog:",
    "@types/node": "^22.13.15",
    "oxfmt": "^0.35.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.2"
}
