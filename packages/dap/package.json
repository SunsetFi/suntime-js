{
  "name": "@suntime-js/dap",
  "version": "0.1.0",
  "private": false,
  "description": "Debug Adapter Protocol bootstrap for StaticJs.",
  "keywords": [],
  "license": "ISC",
  "author": "SunsetFi",
  "files": [
    "lib"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./web": {
      "types": "./lib/web/index.d.ts",
      "import": "./lib/web/index.js"
    }
  },
  "scripts": {
    "prepublish": "pnpm run clean && pnpm run build",
    "clean": "rimraf lib tsconfig.lib.tsbuildinfo tsconfig.tests.tsbuildinfo",
    "build": "tsc -p tsconfig.lib.json",
    "check": "tsc -p tsconfig.lib.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@suntime-js/core": "workspace:*",
    "@suntime-js/debugger": "workspace:*",
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vscode/debugadapter-testsupport": "^1.68.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "catalog:tsLegacy",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.30.2"
}
