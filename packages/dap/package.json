{
  "name": "@suntime-js/dap",
  "version": "0.11.0",
  "private": false,
  "description": "Debug Adapter Protocol bootstrap for StaticJs.",
  "keywords": [],
  "license": "ISC",
  "author": "SunsetFi",
  "repository": {
    "url": "https://github.com/SunsetFi/suntime-js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web": {
      "development": "./src/web/index.ts",
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./web": {
        "types": "./dist/web/index.d.ts",
        "import": "./dist/web/index.js"
      }
    },
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.lib.tsbuildinfo tsconfig.tests.tsbuildinfo",
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt",
    "lint": "oxlint",
    "prepublishOnly": "node ../../scripts/verify-build.mjs"
  },
  "dependencies": {
    "@suntime-js/core": "workspace:^",
    "@suntime-js/debugger": "workspace:^",
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vscode/debugadapter-testsupport": "^1.68.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
