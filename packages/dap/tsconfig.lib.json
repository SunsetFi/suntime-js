{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./lib",
    "declaration": true,
    "rootDir": "./src",
    // These need to stay, as we are using an older version of typescript
    // due to TS6 not supporting the module keyword in d.ts anymore.
    // This collides with @vscode/debugadapter
    "esModuleInterop": true,
    "isolatedModules": true,
    // new TypeScript doesn't like the use of the module keyword.
    "skipLibCheck": true,
    "composite": true
  },
  "include": ["./src"],
  "references": [
    { "path": "../core/tsconfig.lib.json" },
    { "path": "../debugger/tsconfig.lib.json" }
  ]
}
